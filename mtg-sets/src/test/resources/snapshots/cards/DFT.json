                            "type": "Fixed",
                            "amount": 1
                        }
                    },
                    "filter": "artifact|creature",
                    "storeSelected": "toExile",
                    "prompt": "Choose an artifact or creature card to exile"
                },
                {
                    "type": "MoveCollection",
                    "from": "toExile",
                    "destination": {
                        "type": "ToZone",
