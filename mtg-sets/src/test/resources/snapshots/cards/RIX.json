// Path of Discovery
{
    "name": "Path of Discovery",
    "manaCost": "{3}{G}",
    "typeLine": "Enchantment",
    "oracleText": "Whenever a creature you control enters, it explores. (Reveal the top card of your library. Put that card into your hand if it's a land. Otherwise, put a +1/+1 counter on the creature, then put the card back or put it into your graveyard.)",
    "script": {
        "triggeredAbilities": [
            {
                "id": "ability_1",
                "trigger": {
                    "type": "ZoneChangeEvent",
                    "filter": "creature ctrl:you",
                    "to": "Battlefield"
                },
                "binding": "OTHER",
                "effect": {
                    "type": "Explore",
                    "target": "TriggeringEntity"
                }
            }
        ]
    },
    "metadata": {
        "collectorNumber": "142",
        "rarity": "RARE",
        "artist": "Christine Choi",
        "imageUri": "https://cards.scryfall.io/normal/front/a/d/ad9d5518-34ea-418d-b34d-74d773db8bcb.jpg?1555040716",
        "rulings": [
            {
                "date": "2018-01-19",
                "text": "Path of Discovery's triggered ability triggers along with any other abilities that say that the creature explores when it enters the battlefield, including abilities that come from the creature itself or from multiples of Path of Discovery. You may take actions between each resolving ability's exploration."
            }
        ]
    },
    "colorIdentityOverride": [
        "GREEN"
    ]
}
